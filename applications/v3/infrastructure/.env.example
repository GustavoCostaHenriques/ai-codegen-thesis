# Core domain routing
APP_HOST=localhost
PUBLIC_NETWORK_NAME=weekly_planning_public
PRIVATE_NETWORK_NAME=weekly_planning_internal

# Traefik / TLS
TRAEFIK_ACME_EMAIL=ops@example.com

# Frontend build-time API target
FRONTEND_API_BASE_URL=http://localhost/api/v1

# Backend runtime profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
POSTGRES_DB=weekly_planning
POSTGRES_USER=weekly
POSTGRES_PASSWORD=change_me_strong_postgres_password

# Redis
REDIS_PORT=6379

# JWT (minimum 32 random characters recommended)
JWT_SECRET=replace_with_a_long_random_secret_value
JWT_ISSUER=weekly-planning
JWT_EXP_MINUTES=60

# Bootstrapped admin account
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_NAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@weekly.local
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password

# Bootstrapped viewer account (seeded through public account registration API)
VIEWER_NAME=Viewer User
VIEWER_EMAIL=viewer@example.com
VIEWER_PASSWORD=change_me_viewer_password
