<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-align-account-and-project" author="codex">
        <sql splitStatements="true" stripComments="true">
            ALTER TABLE account ADD COLUMN IF NOT EXISTS username VARCHAR(128);
            ALTER TABLE account ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW();
            ALTER TABLE account ALTER COLUMN email TYPE VARCHAR(320);

            UPDATE account
            SET username = LOWER(SPLIT_PART(email, '@', 1)) || '_' || SUBSTRING(REPLACE(id::text, '-', '') FROM 1 FOR 8)
            WHERE username IS NULL;

            ALTER TABLE account ALTER COLUMN username SET NOT NULL;
            ALTER TABLE account ADD CONSTRAINT uk_account_username UNIQUE (username);
            ALTER TABLE account DROP COLUMN IF EXISTS name;
            ALTER TABLE account DROP COLUMN IF EXISTS status;

            ALTER TABLE project ALTER COLUMN name TYPE VARCHAR(120);
            ALTER TABLE project ALTER COLUMN code TYPE VARCHAR(40);
            ALTER TABLE project ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW();
        </sql>
    </changeSet>

    <changeSet id="004-create-person" author="codex">
        <createTable tableName="person">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_id" type="UUID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_person_account"/>
            </column>
            <column name="name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(320)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_person_email"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="person"
                                 baseColumnNames="account_id"
                                 referencedTableName="account"
                                 referencedColumnNames="id"
                                 constraintName="fk_person_account"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="005-create-week-and-planning" author="codex">
        <createTable tableName="week_plan">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(30)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_week_code"/>
            </column>
            <column name="week_start" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="week_end" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="day_plan">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="week_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="day_of_week" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="day_plan"
                             columnNames="week_id,date"
                             constraintName="uk_day_plan_week_date"/>

        <addForeignKeyConstraint baseTableName="day_plan"
                                 baseColumnNames="week_id"
                                 referencedTableName="week_plan"
                                 referencedColumnNames="id"
                                 constraintName="fk_day_plan_week"
                                 onDelete="CASCADE"/>

        <createTable tableName="day_person">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="day_plan_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="person_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="day_person"
                             columnNames="day_plan_id,person_id"
                             constraintName="uk_day_person_unique"/>

        <addForeignKeyConstraint baseTableName="day_person"
                                 baseColumnNames="day_plan_id"
                                 referencedTableName="day_plan"
                                 referencedColumnNames="id"
                                 constraintName="fk_day_person_day_plan"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="day_person"
                                 baseColumnNames="person_id"
                                 referencedTableName="person"
                                 referencedColumnNames="id"
                                 constraintName="fk_day_person_person"/>

        <createTable tableName="day_person_project">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="day_person_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="day_person_project"
                             columnNames="day_person_id,project_id"
                             constraintName="uk_day_person_project_unique"/>

        <addForeignKeyConstraint baseTableName="day_person_project"
                                 baseColumnNames="day_person_id"
                                 referencedTableName="day_person"
                                 referencedColumnNames="id"
                                 constraintName="fk_day_person_project_day_person"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="day_person_project"
                                 baseColumnNames="project_id"
                                 referencedTableName="project"
                                 referencedColumnNames="id"
                                 constraintName="fk_day_person_project_project"/>

        <createTable tableName="task">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="day_person_project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="task"
                                 baseColumnNames="day_person_project_id"
                                 referencedTableName="day_person_project"
                                 referencedColumnNames="id"
                                 constraintName="fk_task_day_person_project"
                                 onDelete="CASCADE"/>

        <createIndex tableName="day_plan" indexName="idx_day_plan_week_id">
            <column name="week_id"/>
        </createIndex>

        <createIndex tableName="day_person" indexName="idx_day_person_person_id">
            <column name="person_id"/>
        </createIndex>

        <createIndex tableName="day_person_project" indexName="idx_day_person_project_project_id">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
