{
  "name": "formacao-angular",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "Description for Formacao Angular",
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run webapp:prod --",
    "build-watch": "concurrently 'npm run webapp:build:dev -- --watch'",
    "ci:frontend:build": "npm run webapp:build:$npm_package_config_default_environment",
    "ci:frontend:test": "npm run ci:frontend:build && npm test",
    "clean-www": "rimraf target/classes/static/",
    "cleanup": "rimraf target/",
    "jest": "jest --coverage --logHeapUsage --maxWorkers=2 --config jest.conf.js",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "prettier:check": "prettier --check \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,css,scss}\"",
    "prettier:format": "prettier --write \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,css,scss}\"",
    "serve": "npm run start --",
    "sonar": "sonar-scanner",
    "start": "ng serve --hmr",
    "start-tls": "npm run webapp:dev-ssl",
    "pretest": "npm run lint",
    "test": "ng test --coverage --log-heap-usage -w=2",
    "test:watch": "npm run test -- --watch",
    "watch": "concurrently npm:start",
    "webapp:build": "npm run clean-www && npm run webapp:build:dev",
    "webapp:build:dev": "ng build --configuration development",
    "webapp:build:prod": "ng build --configuration production",
    "webapp:dev": "ng serve",
    "webapp:dev-ssl": "ng serve --ssl",
    "webapp:dev-verbose": "ng serve --verbose",
    "webapp:prod": "npm run clean-www && npm run webapp:build:prod",
    "webapp:test": "npm run test --"
  },
  "config": {
    "default_environment": "prod"
  },
  "dependencies": {
    "@angular/animations": "19.2.3",
    "@angular/cdk": "19.2.9",
    "@angular/common": "19.2.3",
    "@angular/compiler": "19.2.3",
    "@angular/core": "19.2.3",
    "@angular/forms": "19.2.3",
    "@angular/localize": "19.2.3",
    "@angular/material": "19.2.9",
    "@angular/material-moment-adapter": "19.2.9",
    "@angular/platform-browser": "19.2.3",
    "@angular/platform-browser-dynamic": "19.2.3",
    "@angular/router": "19.2.3",
    "@fortawesome/angular-fontawesome": "1.0.0",
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@ng-bootstrap/ng-bootstrap": "18.0.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "16.0.1",
    "@popperjs/core": "2.11.8",
    "@trustsystems/dynamic-lib": "^0.0.35",
    "bootstrap": "^5.3.3",
    "date-fns": "^4.1.0",
    "dayjs": "1.11.13",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.29.2",
    "moment": "^2.30.1",
    "ng-translate": "^1.0.3",
    "ngx-bootstrap": "^19.0.2",
    "ngx-infinite-scroll": "19.0.0",
    "ngx-mat-select-search": "^8.0.0",
    "ngx-toastr": "^19.0.0",
    "react-native-uuid": "^2.0.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "19.0.0",
    "@angular-builders/jest": "19.0.0",
    "@angular-devkit/build-angular": "19.2.4",
    "@angular/cli": "19.2.5",
    "@angular/compiler-cli": "19.2.3",
    "@angular/service-worker": "19.2.3",
    "@eslint/js": "9.23.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.13",
    "angular-eslint": "19.3.0",
    "browser-sync": "3.0.3",
    "browser-sync-webpack-plugin": "2.3.0",
    "buffer": "6.0.3",
    "concurrently": "9.1.2",
    "copy-webpack-plugin": "13.0.0",
    "eslint": "9.23.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-prettier": "5.2.5",
    "folder-hash": "4.1.1",
    "generator-jhipster": "8.9.0",
    "globals": "16.0.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-date-mock": "1.0.10",
    "jest-environment-jsdom": "29.7.0",
    "jest-junit": "16.0.0",
    "jest-preset-angular": "14.5.3",
    "jest-sonar": "0.2.16",
    "lint-staged": "15.5.0",
    "merge-jsons-webpack-plugin": "2.0.1",
    "prettier": "3.5.3",
    "prettier-plugin-packagejson": "2.5.10",
    "rimraf": "6.0.1",
    "sass": "^1.86.0",
    "sass-loader": "^16.0.5",
    "sonar-scanner": "3.1.0",
    "swagger-ui-dist": "5.20.1",
    "ts-jest": "29.3.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.28.0",
    "wait-on": "8.0.3",
    "webpack-bundle-analyzer": "4.10.2",
    "webpack-merge": "6.0.1",
    "webpack-notifier": "1.15.0"
  },
  "engines": {
    "node": ">=22.13.1"
  },
  "cacheDirectories": [
    "node_modules"
  ],
  "overrides": {
    "browser-sync": "3.0.3",
    "webpack": "5.97.1"
  }
}
