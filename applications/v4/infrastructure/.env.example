COMPOSE_PROJECT_NAME=weekly-planning

# Hostname used by Traefik routing rules.
APP_HOST=localhost

# Explicit network names. PUBLIC_NETWORK_NAME must match traefik.docker.network labels.
PUBLIC_NETWORK_NAME=weekly-public-net
PRIVATE_NETWORK_NAME=weekly-private-net

# PostgreSQL configuration (do not commit real credentials).
POSTGRES_DB=weekly_planning
POSTGRES_USER=weekly_app
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_VOLUME_NAME=weekly-postgres-data

# Redis container port used by backend.
REDIS_PORT=6379

# Backend security and auth settings.
APP_JWT_SECRET=replace-with-strong-random-secret-min-32-chars
APP_JWT_EXPIRATION_SECONDS=900
APP_BRUTE_FORCE_MAX_ATTEMPTS=5
APP_BRUTE_FORCE_LOCK_MINUTES=15
APP_PASSWORD_MIN_LENGTH=8
APP_PASSWORD_REQUIRE_UPPERCASE=false
APP_PASSWORD_REQUIRE_LOWERCASE=false
APP_PASSWORD_REQUIRE_DIGIT=false
APP_PASSWORD_REQUIRE_SPECIAL=false

# Frontend build-time API base URL.
FRONTEND_API_BASE_URL=http://localhost/api/v1

# TLS configuration for Traefik ACME.
LETSENCRYPT_EMAIL=ops@example.com
TRAEFIK_ACME_VOLUME_NAME=weekly-traefik-acme
